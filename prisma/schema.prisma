generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  name      String?
  role      UserRole @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  notifications Notification[]

  // Relations for User Tracking
  createdBrands Brand[] @relation("BrandCreatedBy")
  updatedBrands Brand[] @relation("BrandUpdatedBy")
  createdCategories Category[] @relation("CategoryCreatedBy")
  updatedCategories Category[] @relation("CategoryUpdatedBy")
  createdCollections Collection[] @relation("CollectionCreatedBy")
  updatedCollections Collection[] @relation("CollectionUpdatedBy")
  createdSizes Size[] @relation("SizeCreatedBy")
  updatedSizes Size[] @relation("SizeUpdatedBy")
  createdProducts Product[] @relation("ProductCreatedBy")
  updatedProducts Product[] @relation("ProductUpdatedBy")
  createdLocations Location[] @relation("LocationCreatedBy")
  updatedLocations Location[] @relation("LocationUpdatedBy")
  createdBatches Batch[] @relation("BatchCreatedBy")
  updatedBatches Batch[] @relation("BatchUpdatedBy")
  createdPurchaseOrders PurchaseOrder[] @relation("PurchaseOrderCreatedBy")
  updatedPurchaseOrders PurchaseOrder[] @relation("PurchaseOrderUpdatedBy")
  createdPurchaseItems PurchaseItem[] @relation("PurchaseItemCreatedBy")
  updatedPurchaseItems PurchaseItem[] @relation("PurchaseItemUpdatedBy")
  createdSalesOrders SalesOrder[] @relation("SalesOrderCreatedBy")
  updatedSalesOrders SalesOrder[] @relation("SalesOrderUpdatedBy")
  createdSalesItems SalesItem[] @relation("SalesItemCreatedBy")
  updatedSalesItems SalesItem[] @relation("SalesItemUpdatedBy")

  @@map("users")
}

model Notification {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  userId    String           @db.ObjectId
  title     String
  message   String
  type      NotificationType @default(INFO)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user      User             @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Brand {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  name           String          @unique
  description    String?
  contactInfo    String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  
  createdById    String?         @db.ObjectId
  updatedById    String?         @db.ObjectId
  createdBy      User?           @relation("BrandCreatedBy", fields: [createdById], references: [id])
  updatedBy      User?           @relation("BrandUpdatedBy", fields: [updatedById], references: [id])
  
  products       Product[]
  purchaseOrders PurchaseOrder[]

  @@map("brand")
}

model Category {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  createdById String?   @db.ObjectId
  updatedById String?   @db.ObjectId
  createdBy   User?     @relation("CategoryCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?     @relation("CategoryUpdatedBy", fields: [updatedById], references: [id])
  
  products    Product[]

  @@map("categories")
}

model Collection {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  createdById String?   @db.ObjectId
  updatedById String?   @db.ObjectId
  createdBy   User?     @relation("CollectionCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?     @relation("CollectionUpdatedBy", fields: [updatedById], references: [id])
  
  products    Product[]

  @@map("collections")
}

model Size {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String    @unique
  description String?
  length      Float?
  width       Float?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  createdById String?   @db.ObjectId
  updatedById String?   @db.ObjectId
  createdBy   User?     @relation("SizeCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?     @relation("SizeUpdatedBy", fields: [updatedById], references: [id])
  
  products    Product[]

  @@map("sizes")
}


model Product {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  code          String
  description   String?
  brandId       String        @db.ObjectId
  categoryId    String        @db.ObjectId
  collectionId  String?       @db.ObjectId
  sizeId        String?       @db.ObjectId
  length        Float?
  width         Float?
  thickness     Float?
  sqftPerBox    Float
  pcsPerBox     Int
  imageUrl      String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  createdById   String?       @db.ObjectId
  updatedById   String?       @db.ObjectId
  createdBy     User?         @relation("ProductCreatedBy", fields: [createdById], references: [id])
  updatedBy     User?         @relation("ProductUpdatedBy", fields: [updatedById], references: [id])
  
  brand         Brand         @relation(fields: [brandId], references: [id])
  category      Category      @relation(fields: [categoryId], references: [id])
  collection    Collection?   @relation(fields: [collectionId], references: [id])
  size          Size?         @relation(fields: [sizeId], references: [id])
  
  batches       Batch[]
  purchaseItems PurchaseItem[]
  salesItems    SalesItem[]

  @@map("products")
}

model Location {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  address       String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  createdById   String?        @db.ObjectId
  updatedById   String?        @db.ObjectId
  createdBy     User?          @relation("LocationCreatedBy", fields: [createdById], references: [id])
  updatedBy     User?          @relation("LocationUpdatedBy", fields: [updatedById], references: [id])
  
  batches       Batch[]
  purchaseItems PurchaseItem[]

  @@map("locations")
}

model Batch {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  productId     String   @db.ObjectId
  locationId    String   @db.ObjectId
  batchNumber   String
  shade         String?
  quantity      Int
  purchasePrice Float?
  sellingPrice  Float?
  receivedDate  DateTime?
  expiryDate    DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  createdById   String?  @db.ObjectId
  updatedById   String?  @db.ObjectId
  createdBy     User?    @relation("BatchCreatedBy", fields: [createdById], references: [id])
  updatedBy     User?    @relation("BatchUpdatedBy", fields: [updatedById], references: [id])
  
  product       Product  @relation(fields: [productId], references: [id])
  location      Location @relation(fields: [locationId], references: [id])
  
  salesItems    SalesItem[]

  @@map("batches")
}

model PurchaseOrder {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber   String         @unique
  brandId       String         @db.ObjectId
  orderDate     DateTime
  expectedDate  DateTime?
  receivedDate  DateTime?
  status        OrderStatus    @default(PENDING)
  totalAmount   Float          @default(0)
  notes         String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  createdById    String?        @db.ObjectId
  updatedById    String?        @db.ObjectId
  createdBy      User?          @relation("PurchaseOrderCreatedBy", fields: [createdById], references: [id])
  updatedBy      User?          @relation("PurchaseOrderUpdatedBy", fields: [updatedById], references: [id])
  
  brand         Brand          @relation(fields: [brandId], references: [id])
  items         PurchaseItem[]

  @@map("purchase_orders")
}

model PurchaseItem {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  purchaseOrderId String        @db.ObjectId
  productId       String        @db.ObjectId
  locationId      String        @db.ObjectId
  batchNumber     String
  shade           String?
  quantity        Int
  unitPrice       Float
  totalPrice      Float
  receivedQty     Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  createdById     String?       @db.ObjectId
  updatedById     String?       @db.ObjectId
  createdBy       User?         @relation("PurchaseItemCreatedBy", fields: [createdById], references: [id])
  updatedBy       User?         @relation("PurchaseItemUpdatedBy", fields: [updatedById], references: [id])
  
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  product         Product       @relation(fields: [productId], references: [id])
  location        Location      @relation(fields: [locationId], references: [id])

  @@map("purchase_items")
}

model SalesOrder {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber  String      @unique
  customerName String?
  customerPhone String?
  orderDate    DateTime
  deliveryDate DateTime?
  status       OrderStatus @default(PENDING)
  totalAmount  Float       @default(0)
  discount     Float       @default(0)
  finalAmount  Float       @default(0)
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  
  createdById  String?     @db.ObjectId
  updatedById  String?     @db.ObjectId
  createdBy    User?       @relation("SalesOrderCreatedBy", fields: [createdById], references: [id])
  updatedBy    User?       @relation("SalesOrderUpdatedBy", fields: [updatedById], references: [id])
  
  items        SalesItem[]

  @@map("sales_orders")
}

model SalesItem {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  salesOrderId String     @db.ObjectId
  productId    String     @db.ObjectId
  batchId      String     @db.ObjectId
  quantity     Int
  unitPrice    Float
  totalPrice   Float
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  createdById  String?    @db.ObjectId
  updatedById  String?    @db.ObjectId
  createdBy    User?      @relation("SalesItemCreatedBy", fields: [createdById], references: [id])
  updatedBy    User?      @relation("SalesItemUpdatedBy", fields: [updatedById], references: [id])
  
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])
  product      Product    @relation(fields: [productId], references: [id])
  batch        Batch      @relation(fields: [batchId], references: [id])

  @@map("sales_items")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  RECEIVED
  DELIVERED
  CANCELLED
}

enum UserRole {
  ADMIN
  USER
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}
